# Frontend (Next.js) — variables públicas
# Next.js lee este archivo desde apps/frontend/, NO desde el .env de la raíz.
# Para desarrollo local podés omitirlo: el código cae por defecto a http://localhost:4020/api
# Para producción, copialo a .env.local y apuntá a tu backend desplegado.

NEXT_PUBLIC_API_URL=http://localhost:4020/api
