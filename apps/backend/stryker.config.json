{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing config for SIADLP backend. Validates that unit tests detect real changes (not just coverage).",
  "packageManager": "pnpm",
  "plugins": [
    "@stryker-mutator/jest-runner",
    "@stryker-mutator/typescript-checker"
  ],
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "package.json",
    "enableFindRelatedTests": true
  },
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.build.json",
  "disableTypeChecks": false,
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/auth/auth.service.ts",
    "src/dispatch/dispatch.service.ts",
    "src/orders/orders.service.ts",
    "src/catalogs/clients/clients.service.ts",
    "src/auth/guards/permissions.guard.ts"
  ],
  "ignorePatterns": [
    "dist",
    "coverage",
    "stryker-report",
    ".stryker-tmp",
    "node_modules",
    "uploads",
    "prisma/migrations"
  ],
  "reporters": ["progress", "clear-text", "html"],
  "htmlReporter": {
    "fileName": "stryker-report/mutation-report.html"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 70
  },
  "concurrency": 4,
  "timeoutMS": 60000,
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": true
}
