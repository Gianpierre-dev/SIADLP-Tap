generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                 Int      @id @default(autoincrement())
  correo             String   @unique
  contrasena         String
  nombre             String
  activo             Boolean  @default(true)
  rolId              Int      @map("rol_id")
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  rol Rol @relation(fields: [rolId], references: [id], onDelete: Restrict)

  pedidosCreadoPor           Pedido[]               @relation("PedidoCreadoPor")
  estadoPedidoLogs           EstadoPedidoLog[]
  ordenesCompraCreadoPor     OrdenCompra[]          @relation("OcCreadoPor")
  movimientosInventario      MovimientoInventario[]
  ordenesProduccionCreadoPor OrdenProduccion[]      @relation("ProduccionCreadoPor")
  hojasCargaCreadoPor        HojaCarga[]            @relation("HojaCargaCreadoPor")
  entregas                   Entrega[]
  registrosAuditoria         RegistroAuditoria[]

  @@map("usuarios")
}

model Rol {
  id            Int      @id @default(autoincrement())
  nombre        String   @unique
  descripcion   String?
  activo        Boolean  @default(true)
  fechaCreacion DateTime @default(now()) @map("fecha_creacion")

  usuarios Usuario[]
  permisos RolPermiso[]

  @@map("roles")
}

model Permiso {
  id          Int     @id @default(autoincrement())
  modulo      String
  accion      String
  descripcion String?

  roles RolPermiso[]

  @@unique([modulo, accion])
  @@map("permisos")
}

model RolPermiso {
  rolId     Int @map("rol_id")
  permisoId Int @map("permiso_id")

  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
  @@map("rol_permisos")
}

model Cliente {
  id                 Int      @id @default(autoincrement())
  razonSocial        String   @map("razon_social")
  nombreComercial    String?  @map("nombre_comercial")
  ruc                String?  @unique
  direccion          String
  telefono           String?
  contacto           String?
  ubigeo             String?
  rutaId             Int      @map("ruta_id")
  activo             Boolean  @default(true)
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  ruta Ruta @relation(fields: [rutaId], references: [id], onDelete: Restrict)

  pedidos Pedido[]

  @@index([rutaId])
  @@map("clientes")
}

model Proveedor {
  id                 Int      @id @default(autoincrement())
  razonSocial        String   @map("razon_social")
  ruc                String?  @unique
  direccion          String?
  telefono           String?
  contacto           String?
  activo             Boolean  @default(true)
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  ordenesCompra OrdenCompra[]

  @@map("proveedores")
}

model Producto {
  id                 Int      @id @default(autoincrement())
  nombre             String
  codigoSku          String   @unique @map("codigo_sku")
  descripcion        String?
  unidadMedida       String   @map("unidad_medida")
  precioBase         Decimal  @map("precio_base") @db.Decimal(10, 2)
  stockMinimo        Decimal? @map("stock_minimo") @db.Decimal(10, 2)
  activo             Boolean  @default(true)
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  detallesPedido      DetallePedido[]
  productosProduccion ProductoProduccion[]

  @@map("productos")
}

model Ruta {
  id            Int      @id @default(autoincrement())
  nombre        String   @unique
  zona          String
  tarifa        Decimal  @db.Decimal(10, 2)
  descripcion   String?
  activa        Boolean  @default(true)
  fechaCreacion DateTime @default(now()) @map("fecha_creacion")

  clientes   Cliente[]
  hojasCarga HojaCarga[]

  @@map("rutas")
}

model Vehiculo {
  id            Int      @id @default(autoincrement())
  placa         String   @unique
  marca         String?
  modelo        String?
  capacidadKg   Decimal  @map("capacidad_kg") @db.Decimal(10, 2)
  activo        Boolean  @default(true)
  fechaCreacion DateTime @default(now()) @map("fecha_creacion")

  hojasCarga HojaCarga[]

  @@map("vehiculos")
}

model Chofer {
  id            Int      @id @default(autoincrement())
  nombre        String
  apellido      String
  dni           String   @unique
  licencia      String?
  telefono      String?
  activo        Boolean  @default(true)
  fechaCreacion DateTime @default(now()) @map("fecha_creacion")

  hojasCarga HojaCarga[]

  @@map("choferes")
}

model Pedido {
  id                 Int      @id @default(autoincrement())
  clienteId          Int      @map("cliente_id")
  fechaEntrega       DateTime @map("fecha_entrega") @db.Date
  estado             String   @default("REGISTERED")
  total              Decimal  @default(0) @db.Decimal(10, 2)
  observacion        String?
  creadoPorId        Int      @map("creado_por_id")
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  hojaCargaId        Int?       @map("hoja_carga_id")

  cliente    Cliente           @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  creadoPor  Usuario           @relation("PedidoCreadoPor", fields: [creadoPorId], references: [id], onDelete: Restrict)
  hojaCarga  HojaCarga?        @relation(fields: [hojaCargaId], references: [id], onDelete: SetNull)
  detalles   DetallePedido[]
  estadoLogs EstadoPedidoLog[]
  entrega    Entrega?

  @@index([clienteId])
  @@index([estado])
  @@index([fechaEntrega])
  @@index([hojaCargaId])
  @@index([fechaCreacion])
  @@map("pedidos")
}

model DetallePedido {
  id             Int     @id @default(autoincrement())
  pedidoId       Int     @map("pedido_id")
  productoId     Int     @map("producto_id")
  cantidad       Decimal @db.Decimal(10, 2)
  precioUnitario Decimal @map("precio_unitario") @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  pedido   Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([pedidoId])
  @@index([productoId])
  @@map("detalle_pedidos")
}

model EstadoPedidoLog {
  id             Int      @id @default(autoincrement())
  pedidoId       Int      @map("pedido_id")
  estadoAnterior String?  @map("estado_anterior")
  estadoNuevo    String   @map("estado_nuevo")
  motivo         String?
  usuarioId      Int      @map("usuario_id")
  fechaCreacion  DateTime @default(now()) @map("fecha_creacion")

  pedido  Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([pedidoId])
  @@index([usuarioId])
  @@map("estado_pedido_logs")
}

model OrdenCompra {
  id                 Int      @id @default(autoincrement())
  proveedorId        Int      @map("proveedor_id")
  estado             String   @default("EMITIDA")
  observacion        String?
  total              Decimal  @default(0) @db.Decimal(10, 2)
  creadoPorId        Int      @map("creado_por_id")
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  proveedor Proveedor            @relation(fields: [proveedorId], references: [id], onDelete: Restrict)
  creadoPor Usuario              @relation("OcCreadoPor", fields: [creadoPorId], references: [id], onDelete: Restrict)
  detalles  DetalleOrdenCompra[]

  @@index([proveedorId])
  @@index([estado])
  @@index([fechaCreacion])
  @@map("ordenes_compra")
}

model DetalleOrdenCompra {
  id               Int      @id @default(autoincrement())
  ordenCompraId    Int      @map("orden_compra_id")
  descripcion      String
  unidadMedida     String   @map("unidad_medida")
  cantidad         Decimal  @db.Decimal(10, 2)
  cantidadRecibida Decimal? @map("cantidad_recibida") @db.Decimal(10, 2)
  precioUnitario   Decimal  @map("precio_unitario") @db.Decimal(10, 2)
  subtotal         Decimal  @db.Decimal(10, 2)

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)

  @@index([ordenCompraId])
  @@map("detalle_ordenes_compra")
}

model ItemInventario {
  id           Int      @id @default(autoincrement())
  tipo         String
  nombre       String
  unidadMedida String   @map("unidad_medida")
  stockActual  Decimal  @default(0) @map("stock_actual") @db.Decimal(10, 2)
  stockMinimo  Decimal  @default(0) @map("stock_minimo") @db.Decimal(10, 2)
  activo       Boolean  @default(true)
  fechaCreacion DateTime @default(now()) @map("fecha_creacion")

  movimientos      MovimientoInventario[]
  insumosProduccion InsumoProduccion[]

  @@unique([tipo, nombre])
  @@map("items_inventario")
}

model MovimientoInventario {
  id               Int      @id @default(autoincrement())
  itemInventarioId Int      @map("item_inventario_id")
  tipo             String
  cantidad         Decimal  @db.Decimal(10, 2)
  stockResultante  Decimal  @map("stock_resultante") @db.Decimal(10, 2)
  referencia       String?
  usuarioId        Int      @map("usuario_id")
  fechaCreacion    DateTime @default(now()) @map("fecha_creacion")

  itemInventario ItemInventario @relation(fields: [itemInventarioId], references: [id], onDelete: Restrict)
  usuario        Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([itemInventarioId])
  @@index([fechaCreacion])
  @@map("movimientos_inventario")
}

model OrdenProduccion {
  id                 Int      @id @default(autoincrement())
  fecha              DateTime @db.Date
  estado             String   @default("PENDIENTE")
  observacion        String?
  creadoPorId        Int      @map("creado_por_id")
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  creadoPor Usuario              @relation("ProduccionCreadoPor", fields: [creadoPorId], references: [id], onDelete: Restrict)
  insumos   InsumoProduccion[]
  productos ProductoProduccion[]

  @@index([fecha])
  @@index([estado])
  @@map("ordenes_produccion")
}

model InsumoProduccion {
  id                Int     @id @default(autoincrement())
  ordenProduccionId Int     @map("orden_produccion_id")
  itemInventarioId  Int     @map("item_inventario_id")
  cantidad          Decimal @db.Decimal(10, 2)
  costoUnitario     Decimal @map("costo_unitario") @db.Decimal(10, 2)
  costoTotal        Decimal @map("costo_total") @db.Decimal(10, 2)

  ordenProduccion OrdenProduccion @relation(fields: [ordenProduccionId], references: [id], onDelete: Cascade)
  itemInventario  ItemInventario  @relation(fields: [itemInventarioId], references: [id], onDelete: Restrict)

  @@map("insumos_produccion")
}

model ProductoProduccion {
  id                Int     @id @default(autoincrement())
  ordenProduccionId Int     @map("orden_produccion_id")
  productoId        Int     @map("producto_id")
  cantidad          Decimal @db.Decimal(10, 2)

  ordenProduccion OrdenProduccion @relation(fields: [ordenProduccionId], references: [id], onDelete: Cascade)
  producto        Producto        @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@map("productos_produccion")
}

model HojaCarga {
  id                 Int      @id @default(autoincrement())
  fecha              DateTime @db.Date
  rutaId             Int      @map("ruta_id")
  vehiculoId         Int      @map("vehiculo_id")
  choferId           Int      @map("chofer_id")
  estado             String   @default("PREPARANDO")
  numeroGre          String?  @map("numero_gre")
  totalKg            Decimal  @default(0) @map("total_kg") @db.Decimal(10, 2)
  totalMonto         Decimal  @default(0) @map("total_monto") @db.Decimal(10, 2)
  creadoPorId        Int      @map("creado_por_id")
  fechaCreacion      DateTime @default(now()) @map("fecha_creacion")
  fechaActualizacion DateTime @updatedAt @map("fecha_actualizacion")

  ruta      Ruta      @relation(fields: [rutaId], references: [id], onDelete: Restrict)
  vehiculo  Vehiculo  @relation(fields: [vehiculoId], references: [id], onDelete: Restrict)
  chofer    Chofer    @relation(fields: [choferId], references: [id], onDelete: Restrict)
  creadoPor Usuario   @relation("HojaCargaCreadoPor", fields: [creadoPorId], references: [id], onDelete: Restrict)
  pedidos   Pedido[]

  @@index([fecha])
  @@index([estado])
  @@index([rutaId])
  @@map("hojas_carga")
}

model Entrega {
  id                Int       @id @default(autoincrement())
  pedidoId          Int       @unique @map("pedido_id")
  estado            String    @default("PENDIENTE")
  montoCobrado      Decimal?  @map("monto_cobrado") @db.Decimal(10, 2)
  metodoPago        String?   @map("metodo_pago")
  numeroComprobante String?   @map("numero_comprobante")
  observacion       String?
  registradoPorId   Int       @map("registrado_por_id")
  fechaEntrega      DateTime? @map("fecha_entrega")
  fechaCreacion     DateTime  @default(now()) @map("fecha_creacion")

  pedido        Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  registradoPor Usuario @relation(fields: [registradoPorId], references: [id], onDelete: Restrict)

  @@index([estado])
  @@index([fechaEntrega])
  @@map("entregas")
}

model RegistroAuditoria {
  id            Int      @id @default(autoincrement())
  usuarioId     Int      @map("usuario_id")
  accion        String
  modulo        String
  entidadId     Int?     @map("entidad_id")
  detalle       String?
  ip            String?
  fechaCreacion DateTime @default(now()) @map("fecha_creacion")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Restrict)

  @@index([usuarioId])
  @@index([modulo])
  @@index([fechaCreacion])
  @@map("registro_auditoria")
}
