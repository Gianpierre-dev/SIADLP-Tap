# ============================================================
#  SIADLP — Variables de entorno (plantilla)
#  Copiá este archivo a ".env" en la raíz:  cp .env.example .env
# ============================================================

# Base de datos — la password (sql) debe coincidir con docker-compose.yml
DATABASE_URL="postgresql://postgres:sql@localhost:5432/siadlp_db"

# Autenticación — generá tu propio secreto:  openssl rand -hex 32
JWT_SECRET="cambia-esto-por-un-secreto-de-32-o-mas-caracteres"
JWT_EXPIRES_IN="2h"

# Servidor backend
API_PORT=4020
CORS_ORIGINS=http://localhost:3020

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4020/api
